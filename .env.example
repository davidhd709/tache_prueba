# Opción 1 (recomendada): URL directa del script de configuración generado por Botpress
# Ejemplo: https://files.bpcontent.cloud/2026/04/28/xx/xxxxxxxxxxxxxxxx.js
VITE_BOTPRESS_CONFIG_URL=

# Opción 2: URL shareable de Botpress (si no usas la URL directa)
# Ejemplo: https://cdn.botpress.cloud/webchat/v3.6/shareable.html?configUrl=https://files.bpcontent.cloud/...js
VITE_BOTPRESS_SHAREABLE_URL=

# Script injector de Webchat
VITE_BOTPRESS_INJECT_URL=https://cdn.botpress.cloud/webchat/v3.6/inject.js
